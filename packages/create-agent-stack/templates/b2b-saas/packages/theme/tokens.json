{
  "colors": {
    "background": "#ffffff",
    "foreground": "#111827",
    "surface": "#f8fafc",
    "muted": "#64748b",
    "accent": "#2563eb",
    "danger": "#dc2626",
    "success": "#16a34a",
    "focusRing": "#38bdf8"
  },
  "typography": {
    "fontFamily": "Inter, system-ui, sans-serif",
    "fontSize": {
      "sm": 14,
      "md": 16,
      "lg": 20
    },
    "lineHeight": {
      "tight": 1.2,
      "normal": 1.5,
      "relaxed": 1.7
    }
  },
  "spacing": {
    "xs": 4,
    "sm": 8,
    "md": 16,
    "lg": 24,
    "xl": 32
  },
  "radius": {
    "sm": 4,
    "md": 8,
    "lg": 12
  },
  "shadow": {
    "sm": "0 1px 2px rgb(15 23 42 / 0.08)",
    "md": "0 8px 24px rgb(15 23 42 / 0.10)",
    "lg": "0 18px 40px rgb(15 23 42 / 0.14)"
  },
  "motion": {
    "durationFast": 120,
    "durationNormal": 180,
    "easingStandard": "cubic-bezier(0.2, 0, 0, 1)"
  },
  "density": {
    "controlHeight": 40,
    "listItemHeight": 48
  }
}
