NEXT_PUBLIC_CONVEX_URL=<convex-url>
STRIPE_MODE=sandbox
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
EAS_PROJECT_ID=replace-me
VERCEL_PROJECT_ID=replace-me
