{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "lib": ["ES2021"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true
  },
  "include": ["App.tsx", "app.config.ts", "src/**/*.ts", "src/**/*.tsx"]
}
