{
  "name": "agentstack-framework",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build": "pnpm -r --if-present build",
    "format:check": "tsx packages/cli/src/bin.ts format --check",
    "typecheck": "tsc -p tsconfig.base.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "pnpm typecheck"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "commander": "^12.1.0",
    "fs-extra": "^11.2.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8",
    "zod": "^3.24.1"
  }
}
