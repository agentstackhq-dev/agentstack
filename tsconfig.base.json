{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@agentstackhq/adapters": ["packages/adapters/src/index.ts"],
      "@agentstackhq/cli": ["packages/cli/src/index.ts"],
      "@agentstackhq/core": ["packages/core/src/index.ts"],
      "@agentstackhq/telemetry": ["packages/telemetry/src/index.ts"]
    },
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": ".",
    "types": ["node", "vitest/globals"]
  },
  "include": ["packages/**/*.ts", "tests/**/*.ts", "vitest.config.ts"],
  "exclude": [
    "**/dist/**",
    "**/node_modules/**",
    "**/.agentstack/**",
    "packages/agentstack/templates/**"
  ]
}
